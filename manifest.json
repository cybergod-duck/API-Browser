{
  "manifest_version": 3,
  "name": "AI Browse — Model Router",
  "version": "1.1.0",
  "description": "Live model discovery and intelligent routing for browser automation. Auto-discovers models from your providers and scores them for automation suitability.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.moonshot.ai/*",
    "https://api.x.ai/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/api/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "logo.PNG",
      "48": "logo.PNG",
      "128": "logo.PNG"
    }
  },
  "side_panel": {
    "default_path": "src/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/secure_config.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "logo.PNG",
    "48": "logo.PNG",
    "128": "logo.PNG"
  }
}
